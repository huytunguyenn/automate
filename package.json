{
  "name": "automate-local",
  "version": "1.2.0",
  "type": "module",
  "private": true,
  "description": "Kobiton plugin manifests, tool schemas, and skills for AI coding assistants",
  "scripts": {
    "build:codex": "node scripts/sync-codex-artifacts.js",
    "build:tools": "node scripts/build-tool-definitions.js",
    "build": "pnpm run build:tools && pnpm run build:codex",
    "validate": "node scripts/validate.js && node scripts/sync-codex-artifacts.js --check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ejs": "^5.0.1"
  }
}
